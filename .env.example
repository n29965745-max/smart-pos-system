# Copy to .env.local and fill in real values. Never commit .env.local.

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
DATABASE_URL=postgresql://postgres.your-project:your_password@aws-0-region.pooler.supabase.com:6543/postgres

# Auth / crypto
JWT_SECRET=generate_a_long_random_string
JWT_REFRESH_SECRET=generate_another_long_random_string
ENCRYPTION_KEY=64_char_hex_or_random_string

# Redis (optional)
REDIS_URL=redis://default:your_password@your-redis-host:6379

# App
NODE_ENV=development
BACKEND_URL=http://localhost:4000
CRON_SECRET=generate_a_random_cron_secret
SMS_TEST_MODE=true
SMS_PROVIDER=celcom

# SMS – Celcom
CELCOM_API_KEY=your_celcom_api_key
CELCOM_PARTNER_ID=your_partner_id
CELCOM_SENDER_ID=your_sender_id

# SMS – Africa's Talking (optional)
AFRICASTALKING_USERNAME=your_username
AFRICASTALKING_API_KEY=your_africastalking_api_key

# SMS – other providers (optional)
SMSLEOPARD_ACCESS_TOKEN=your_token
SMSLEOPARD_SENDER_ID=your_sender_id
MOBITECH_API_KEY=your_mobitech_key
MOBITECH_ACCOUNT=your_account
MOBITECH_SENDER_ID=your_sender_id
