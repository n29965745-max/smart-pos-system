{
  "name": "smart-pos-backend-per-tenant",
  "version": "2.0.0",
  "description": "Smart POS System - Database-Per-Tenant Backend",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "migrate:registry": "ts-node src/core/database/migrations/registry-schema.ts",
    "provision-tenant": "ts-node src/core/database/provision-tenant-cli.ts",
    "export-tenant": "ts-node src/migration/export-tenant-data.ts",
    "import-tenant": "ts-node src/migration/import-tenant-data.ts",
    "validate-tenant": "ts-node src/migration/validate-migration.ts",
    "test": "jest",
    "test:integration": "jest --config jest.integration.config.js",
    "test:load": "artillery run load-test.yml",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "keywords": [
    "pos",
    "multi-tenant",
    "database-per-tenant",
    "saas",
    "inventory",
    "sales"
  ],
  "author": "Bruno Wachira",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "pg": "^8.11.3",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "compression": "^1.7.4",
    "dotenv": "^16.3.1",
    "winston": "^3.11.0",
    "joi": "^17.11.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.5",
    "@types/pg": "^8.10.9",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/compression": "^1.7.5",
    "typescript": "^5.3.3",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.11",
    "ts-jest": "^29.1.1",
    "eslint": "^8.56.0",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "prettier": "^3.1.1",
    "artillery": "^2.0.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
