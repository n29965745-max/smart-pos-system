# ============================================================================
# SMART POS SYSTEM - DATABASE-PER-TENANT BACKEND
# Environment Configuration
# ============================================================================

# ----------------------------------------------------------------------------
# APPLICATION
# ----------------------------------------------------------------------------
NODE_ENV=production
PORT=3001

# Allowed domains for subdomain-based tenant resolution
# Example: shop1.yourpos.com, shop2.yourpos.com
ALLOWED_DOMAINS=yourpos.com,localhost

# Allowed origins for CORS
ALLOWED_ORIGINS=https://yourpos.com,https://www.yourpos.com,http://localhost:3000

# ----------------------------------------------------------------------------
# CENTRAL REGISTRY DATABASE
# Stores tenant metadata, users, and tenant-user mappings
# ----------------------------------------------------------------------------
REGISTRY_DB_HOST=localhost
REGISTRY_DB_PORT=5432
REGISTRY_DB_NAME=registry_db
REGISTRY_DB_USER=postgres
REGISTRY_DB_PASSWORD=your_registry_db_password

# ----------------------------------------------------------------------------
# POSTGRESQL ADMIN CREDENTIALS
# Used for creating new tenant databases
# ----------------------------------------------------------------------------
DB_ADMIN_USER=postgres
DB_ADMIN_PASSWORD=your_admin_password
DB_HOST=localhost
DB_PORT=5432

# ----------------------------------------------------------------------------
# OLD SHARED DATABASE (For Migration Only)
# Connection to the old tenant_id-based shared database
# ----------------------------------------------------------------------------
OLD_DB_HOST=localhost
OLD_DB_PORT=5432
OLD_DB_NAME=smart_pos_shared
OLD_DB_USER=postgres
OLD_DB_PASSWORD=your_old_db_password

# ----------------------------------------------------------------------------
# REDIS
# Used for caching tenant configurations and session management
# ----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ----------------------------------------------------------------------------
# SECURITY
# ----------------------------------------------------------------------------

# JWT Secret Key (generate with: openssl rand -hex 32)
JWT_SECRET=your_jwt_secret_key_here_use_openssl_rand_hex_32

# JWT Expiration
JWT_EXPIRES_IN=7d

# Database Encryption Key (generate with: openssl rand -hex 32)
# Used to encrypt tenant database credentials in registry
DB_ENCRYPTION_KEY=your_32_byte_hex_encryption_key_here

# Bcrypt Salt Rounds
BCRYPT_ROUNDS=10

# ----------------------------------------------------------------------------
# MIGRATION SETTINGS
# ----------------------------------------------------------------------------

# Directory for exported tenant data
EXPORT_DIR=./exports

# Batch size for bulk operations
MIGRATION_BATCH_SIZE=100

# ----------------------------------------------------------------------------
# CONNECTION POOLING
# ----------------------------------------------------------------------------

# Registry database pool
REGISTRY_POOL_MAX=20
REGISTRY_POOL_MIN=5
REGISTRY_POOL_IDLE_TIMEOUT=30000

# Tenant database pool (per tenant)
TENANT_POOL_MAX=10
TENANT_POOL_MIN=2
TENANT_POOL_IDLE_TIMEOUT=30000

# ----------------------------------------------------------------------------
# LOGGING
# ----------------------------------------------------------------------------

# Log level: error, warn, info, debug
LOG_LEVEL=info

# Log directory
LOG_DIR=./logs

# ----------------------------------------------------------------------------
# RATE LIMITING
# ----------------------------------------------------------------------------

# Requests per minute per IP
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ----------------------------------------------------------------------------
# FILE UPLOADS
# ----------------------------------------------------------------------------

# Maximum file size (in bytes)
MAX_FILE_SIZE=10485760

# Upload directory
UPLOAD_DIR=./uploads

# ----------------------------------------------------------------------------
# EMAIL (Optional - for notifications)
# ----------------------------------------------------------------------------

# SMTP Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_email_password

# Email from address
EMAIL_FROM=noreply@yourpos.com

# ----------------------------------------------------------------------------
# MONITORING (Optional)
# ----------------------------------------------------------------------------

# Sentry DSN for error tracking
SENTRY_DSN=

# New Relic License Key
NEW_RELIC_LICENSE_KEY=

# ----------------------------------------------------------------------------
# BACKUP (Optional)
# ----------------------------------------------------------------------------

# S3 Bucket for backups
AWS_S3_BUCKET=your-backup-bucket
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1

# ----------------------------------------------------------------------------
# DEVELOPMENT ONLY
# ----------------------------------------------------------------------------

# Enable debug mode
DEBUG=false

# Enable SQL query logging
LOG_SQL_QUERIES=false

# Disable authentication (NEVER use in production!)
DISABLE_AUTH=false

# ----------------------------------------------------------------------------
# NOTES
# ----------------------------------------------------------------------------

# 1. Generate secure keys:
#    JWT_SECRET: openssl rand -hex 32
#    DB_ENCRYPTION_KEY: openssl rand -hex 32
#
# 2. Never commit this file with real credentials
#
# 3. Use different credentials for each environment
#
# 4. Rotate keys regularly (every 90 days recommended)
#
# 5. Keep backups of encryption keys securely
#    (If lost, tenant DB credentials cannot be decrypted!)
